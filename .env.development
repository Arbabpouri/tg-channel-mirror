# Path to the session file directory or file path
SESSION_PATH=./sessions/my_account

# Name of the session (without extension)
SESSION_NAME=user_session

# API ID from https://my.telegram.org
API_ID=1234567

# API Hash from https://my.telegram.org
API_HASH=0123456789abcdef0123456789abcdef

# Bot token from @BotFather on Telegram
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Admins ids
ADMINS_IDS=[123456789, 987654321]
